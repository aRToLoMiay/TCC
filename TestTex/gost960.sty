\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{extraMath}[2023/01/29 Additional mathematical symbols and notations.]

% БАЗОВЫЕ
\newcommand{\vr}[1]{\textbfit{#1}} % Vector (Вектор)
\newcommand{\pr}[1]{\mathbb{#1}} % Space (Пространство)

% Дополнитенльые буквенные обозначения.
\newcommand{\E}{\widetilde{E}}
\newcommand{\n}{\vec{n}}
\newcommand{\byV}{\frac{1}{V}}
% Дифференциальные операторы.
\newcommand{\D}{\partial}
\newcommand{\DT}{\partial T}
\newcommand{\ddx}[1]{\frac{\partial}{\partial x_{#1}}}
\newcommand{\dsdx}[2]{\frac{\D \sigma_{#1}}{\D x_{#2}}}
\newcommand{\dudx}[2]{\frac{\D u_{#1}}{\D x_{#2}}}
\newcommand{\dudtt}[1]{\frac{\D^2 u_{#1}}{\D t^2}}
